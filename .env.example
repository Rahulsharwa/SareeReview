BASEROW_BASE_URL=https://api.baserow.io

# Saree Review Portal
SAREE_BASEROW_DATABASE_ID=419522
SAREE_BASEROW_TOKEN=YOUR_SAREE_REST_DATABASE_TOKEN

# Social Media Review Portal
SOCIAL_BASEROW_DATABASE_ID=414089
SOCIAL_BASEROW_TOKEN=YOUR_SOCIAL_REST_DATABASE_TOKEN

# Optional portal auth
APP_REVIEW_PASSWORD=YOUR_PORTAL_PASSWORD

UPLOAD_BASEROW_API_URL=https://api.baserow.io
UPLOAD_BASEROW_TOKEN=YOUR_UPLOAD_SAREE_DATABASE_TOKEN
UPLOAD_BASEROW_TABLE_ID=1076991
UPLOAD_FIELD_PRODUCT_TITLE=9535465
UPLOAD_FIELD_PRODUCT_CODE=9535466
UPLOAD_FIELD_CATEGORY=9535467
UPLOAD_FIELD_PRICE=9535468
UPLOAD_FIELD_SAREE_IMAGE=9535469
UPLOAD_FIELD_BLOUSE_IMAGE=9535470
UPLOAD_FIELD_GENERATION_STATUS=9535471
UPLOAD_FIELD_COMMENT_NOTES=9535472
UPLOAD_FIELD_FRONT_VIEW=9535578
UPLOAD_FIELD_BACK_VIEW=9535579
UPLOAD_FIELD_SIDE_VIEW=9535580
UPLOAD_FIELD_CLOSE_UP=9535581
UPLOAD_GENERATION_STATUS_START=Start
UPLOAD_GENERATION_STATUS_APPROVED=Approved
UPLOAD_GENERATION_STATUS_FAILED=Failed
MAX_UPLOAD_SIZE_MB=50
UPLOAD_MAX_FILES=2
UPLOAD_CLIENT_TIMEOUT_MS=900000
UPLOAD_BLOB_PREFIX=upload-saree/staging
UPLOAD_DIRECT_STORAGE_ENABLED=true
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/jpg,image/png,image/webp
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=20
UPLOAD_SAREE_CACHE_VERSION=v3

BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
BLOB_WEBHOOK_PUBLIC_KEY=
VERCEL_OIDC_TOKEN=

PORT=3003
CACHE_ENABLED=true
CACHE_PROVIDER=redis
REDIS_URL=redis://default:password@host:port
CACHE_PREFIX=jsh:saree-review:
CACHE_TTL_PRODUCTS_SECONDS=60
CACHE_TTL_COLLECTIONS_SECONDS=180
CACHE_TTL_FIELDS_SECONDS=86400
CACHE_TTL_DIAGNOSE_SECONDS=60
CACHE_STALE_IF_ERROR=true

# Optional legacy Upstash provider:
# CACHE_PROVIDER=upstash
# UPSTASH_REDIS_REST_URL=https://YOUR-UPSTASH-ENDPOINT.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN

# Multi-table mode:
# Table IDs are configured in server.js SAREE_TABLES.
# Do not use BASEROW_TABLE_ID for production multi-collection sync.
#
# SAREE_BASEROW_TOKEN must be a REST database token created inside Baserow database 419522.
# It must have read/update access to all 18 saree tables and update access to:
# - SHOPIFY
# - Approvel
# - Comment
#
# SOCIAL_BASEROW_TOKEN must be a separate REST database token created inside Baserow database 414089.
#
# Do not paste the MCP endpoint token here.
